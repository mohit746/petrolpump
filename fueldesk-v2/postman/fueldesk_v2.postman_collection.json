{
  "info": {
    "name": "FuelDesk v2",
    "_postman_id": "5d0a5c38-fueldesk-v2-collection",
    "description": "REST collection covering auth, platform-owner RPCs, tenant analytics RPCs, fuel-pricing & salary RPCs, plus representative direct-table reads against your Supabase backend.\n\nAll requests are pre-wired to the env variables `supabase_url`, `anon_key`, and `access_token`. Use the **Auth → Sign in (email)** request first; its test script captures the JWT into `access_token` automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "variable": [],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign in (email)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.environment.set('access_token', json.access_token);",
                  "  pm.environment.set('user_id',      json.user && json.user.id);",
                  "  pm.test('captured access_token', () => pm.expect(json.access_token).to.be.a('string'));",
                  "} else {",
                  "  pm.test('login failed: ' + (json.error_description || json.msg || 'unknown'),",
                  "          () => pm.expect.fail());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{supabase_url}}/auth/v1/token?grant_type=password",
              "host": ["{{supabase_url}}"],
              "path": ["auth", "v1", "token"],
              "query": [{ "key": "grant_type", "value": "password" }]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{login_email}}\",\n  \"password\": \"{{login_password}}\"\n}"
            }
          }
        },
        {
          "name": "Sign in (mobile → email via RPC)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "apikey",       "value": "{{anon_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/rpc/get_email_by_phone",
              "host": ["{{supabase_url}}"], "path": ["rest","v1","rpc","get_email_by_phone"]
            },
            "body": { "mode": "raw", "raw": "{ \"input_phone\": \"9876543210\" }" }
          }
        },
        {
          "name": "Refresh session",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "apikey",       "value": "{{anon_key}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{supabase_url}}/auth/v1/token?grant_type=refresh_token",
              "host": ["{{supabase_url}}"], "path": ["auth","v1","token"],
              "query": [{ "key": "grant_type", "value": "refresh_token" }]
            },
            "body": { "mode": "raw", "raw": "{ \"refresh_token\": \"{{refresh_token}}\" }" }
          }
        },
        {
          "name": "Get current user (whoami)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{supabase_url}}/auth/v1/user",
              "host": ["{{supabase_url}}"], "path": ["auth","v1","user"]
            }
          }
        }
      ]
    },

    {
      "name": "Permissions (RBAC)",
      "item": [
        {
          "name": "has_permission (RPC)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/rpc/has_permission",
              "host": ["{{supabase_url}}"], "path": ["rest","v1","rpc","has_permission"]
            },
            "body": { "mode": "raw", "raw": "{ \"uid\": \"{{user_id}}\", \"perm\": \"fuel_price.update\" }" }
          }
        },
        {
          "name": "List role defaults",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/role_permissions?select=role,permission&order=role",
              "host": ["{{supabase_url}}"], "path": ["rest","v1","role_permissions"],
              "query": [
                { "key": "select", "value": "role,permission" },
                { "key": "order",  "value": "role" }
              ]
            }
          }
        }
      ]
    },

    {
