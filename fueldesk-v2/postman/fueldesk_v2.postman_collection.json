            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/rpc/create_pump_with_super_admin",
              "host": ["{{supabase_url}}"], "path": ["rest","v1","rpc","create_pump_with_super_admin"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"p_name\": \"Demo Pump\",\n  \"p_address\": \"123 Main St\",\n  \"p_city\": \"Bengaluru\",\n  \"p_state\": \"KA\",\n  \"p_subscription_plan\": \"BASIC\",\n  \"p_monthly_fee\": 999,\n  \"p_owner_auth_id\": \"REPLACE_WITH_AUTH_USER_UUID\",\n  \"p_owner_email\": \"superadmin@example.com\",\n  \"p_owner_first_name\": \"Demo\",\n  \"p_owner_last_name\": \"Admin\",\n  \"p_owner_phone\": \"9876543210\"\n}"
            },
            "description": "Atomic: insert pump + super_admin profile + seed defaults. Caller must be PLATFORM_OWNER. The auth user must already exist in auth.users — use the Auth → Sign up flow in your client first to mint it."
