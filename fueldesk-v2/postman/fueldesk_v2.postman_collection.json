    {
      "name": "Direct Tables (sample reads)",
      "item": [
        {
          "name": "users (same pump)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/users?pump_id=eq.{{pump_id}}&deleted_at=is.null&select=id,first_name,last_name,role,is_active,is_blocked,phone&order=role",
              "host": ["{{supabase_url}}"], "path": ["rest","v1","users"],
              "query": [
                { "key": "pump_id",    "value": "eq.{{pump_id}}" },
                { "key": "deleted_at", "value": "is.null" },
                { "key": "select",     "value": "id,first_name,last_name,role,is_active,is_blocked,phone" },
                { "key": "order",      "value": "role" }
              ]
            }
          }
        },
        {
          "name": "daily_sales (last 7 days)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/daily_sales?pump_id=eq.{{pump_id}}&sale_date=gte.{{from_date}}&select=*&order=sale_date.desc",
              "host": ["{{supabase_url}}"], "path": ["rest","v1","daily_sales"],
              "query": [
                { "key": "pump_id",   "value": "eq.{{pump_id}}" },
                { "key": "sale_date", "value": "gte.{{from_date}}" },
                { "key": "select",    "value": "*" },
                { "key": "order",     "value": "sale_date.desc" }
              ]
            }
          }
        },
        {
          "name": "audit_log (latest 50)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
