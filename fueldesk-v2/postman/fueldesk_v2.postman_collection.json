            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/rpc/platform_global_stats",
              "host": ["{{supabase_url}}"], "path": ["rest","v1","rpc","platform_global_stats"]
            },
            "body": { "mode": "raw", "raw": "{}" }
          }
        },
        {
          "name": "v_pump_health (top by 7-day revenue)",
