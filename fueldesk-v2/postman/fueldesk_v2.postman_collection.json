              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/rpc/cancel_advance",
              "host": ["{{supabase_url}}"], "path": ["rest","v1","rpc","cancel_advance"]
            },
            "body": { "mode": "raw", "raw": "{ \"p_advance_id\": \"REPLACE_WITH_ADVANCE_UUID\", \"p_reason\": \"entered in error\" }" }
