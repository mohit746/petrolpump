            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/v_salary_month_summary?pump_id=eq.{{pump_id}}&year=eq.{{current_year}}&month=eq.{{current_month}}&select=*",
              "host": ["{{supabase_url}}"], "path": ["rest","v1","v_salary_month_summary"],
              "query": [
                { "key": "pump_id", "value": "eq.{{pump_id}}" },
                { "key": "year",    "value": "eq.{{current_year}}" },
