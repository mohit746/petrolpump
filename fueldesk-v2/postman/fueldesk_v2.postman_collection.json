    {
      "name": "Fuel & Pricing",
      "item": [
        {
          "name": "List fuel_types",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{supabase_url}}/rest/v1/fuel_types?pump_id=eq.{{pump_id}}&select=*&order=code",
              "host": ["{{supabase_url}}"], "path": ["rest","v1","fuel_types"],
              "query": [
                { "key": "pump_id", "value": "eq.{{pump_id}}" },
                { "key": "select",  "value": "*" },
                { "key": "order",   "value": "code" }
              ]
            }
          }
        },
        {
          "name": "Insert fuel_price (auto-closes previous)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey",        "value": "{{anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Prefer",        "value": "return=representation" }
